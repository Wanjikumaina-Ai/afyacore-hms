{
    "name": "afyacore-hms",
    "version": "1.0.0",
    "description": "AfyaCore Enterprise Hospital Management System",
    "private": true,
    "scripts": {
        "dev": "concurrently \"pnpm run dev:vite\" \"pnpm run dev:electron:server\"",
        "dev:vite": "vite --port 5173",
        "dev:client": "vite --port 5174 --config vite.client.config.ts",
        "dev:electron:server": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron electron/server/main.cjs",
        "dev:electron:client": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron electron/client/main.cjs",
        "build": "npm run build:server && npm run build:client",
        "build:server": "tsc -b && vite build --config vite.server.config.ts && electron-builder --config electron-builder.server.json",
        "build:client": "vite build --config vite.client.config.ts && electron-builder --config electron-builder.client.json",
        "build:win:server": "electron-builder --win --config electron-builder.server.json",
        "build:win:client": "electron-builder --win --config electron-builder.client.json",
        "seed": "tsx src/lib/auth/rbac-seeder.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit"
    },
    "main": "electron/server/main.cjs",
    "dependencies": {
        "@hono/node-server": "^1.12.0",
        "@tanstack/react-query": "^5.56.0",
        "@tanstack/react-table": "^8.20.0",
        "bcryptjs": "^2.4.3",
        "hono": "^4.5.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-idle-timer": "^5.7.2",
        "react-router": "^7.0.0",
        "recharts": "^2.13.0",
        "sql.js": "^1.12.0",
        "ws": "^8.18.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@esbuild-kit/esm-loader": "^2.6.5",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.5.5",
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@types/ws": "^8.5.12",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.0.1",
        "cross-env": "^7.0.3",
        "electron": "^33.0.0",
        "electron-builder": "^25.0.5",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.3",
        "typescript": "^5.5.4",
        "vite": "^5.4.6",
        "vitest": "^2.1.1",
        "wait-on": "^8.0.1"
    }
}